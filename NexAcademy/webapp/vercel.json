{
    "framework": "nextjs",
    "crons": [
        {
            "path": "/api/cron/sync-points",
            "schedule": "0 0 * * *"
        },
        {
            "path": "/api/cron/scan-passports",
            "schedule": "15 0 * * *"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Permissions-Policy",
                    "value": "microphone=*, camera=*, geolocation=()"
                }
            ]
        }
    ]
}
