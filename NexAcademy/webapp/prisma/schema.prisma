generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.0.x", "debian-openssl-1.1.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  walletAddress    String   @unique
  nonce            String
  discordId        String?
  totalPoints      Int      @default(0)
  isAdmin          Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  shadowBanned     Boolean  @default(false)

  /// Verification tier: BASIC (video+quiz), VERIFIED (+onchain), EXPERT (+agent session)
  verificationTier VerificationTier @default(NONE)

  enrollments      UserCourse[]
  lessonProgress   UserLesson[]

  notes            UserNote[]
  scormRuns        ScormRun[]
  scoreActionNonces ScoreActionNonce[]
  transactions     BlockchainTx[]

  campaignParticipations        CampaignParticipant[]
  domainClaims                  DomainClaim[]
  submittedCampaignRequests     CampaignRequest[]          @relation("SubmittedCampaignRequests")
  reviewedCampaignRequests      CampaignRequest[]          @relation("ReviewedCampaignRequests")
  executedCampaignDistributions CampaignRewardDistribution[] @relation("CampaignDistributionExecutor")
  partner                       Partner?
  passportScore                 PassportScore?
  badges                        Badge[]
  badgeDisplay                  UserBadgeDisplay?
  sybilFlags                    SybilFlag[]
  sessionFingerprints           SessionFingerprint[]
  agentSessions                 AgentSession[]
  quizAttempts                  QuizAttempt[]
  onchainVerifications          OnchainVerification[]
}

enum PartnerVerificationStatus {
  UNVERIFIED
  PENDING_REVIEW
  VERIFIED
  REJECTED
}

enum PartnerTier {
  STANDARD
  PREMIUM
  ENTERPRISE
}

model Partner {
  id                    String                    @id @default(cuid())
  userId                String                    @unique
  orgName               String
  namespace             String                    @unique
  tier                  PartnerTier               @default(STANDARD)

  /// Verification / KYC fields
  verificationStatus    PartnerVerificationStatus @default(UNVERIFIED)
  verifiedAt            DateTime?
  verifiedBy            String?
  rejectionReason       String?

  /// Entity information for KYC
  websiteUrl            String?
  socialUrl             String?
  entityType            String?
  entityRegistration    String?
  contactEmail          String?
  description           String?                   @db.Text

  /// Public visibility (only verified partners appear in directory)
  isPubliclyVisible     Boolean                   @default(false)

  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([namespace])
  @@index([verificationStatus])
  @@index([isPubliclyVisible])
}

model Course {
  id                  Int      @id
  title               String
  description         String
  longDescription     String   @db.Text
  instructor          String
  category            String
  level               CourseLevel
  thumbnailUrl        String?
  duration            String
  objectives          String[]
  prerequisites       String[]
  completionPoints    Int
  keyTakeaways        String[]
  isIncentivized      Boolean  @default(false)
  scormVersion        ScormVersion?
  scormLaunchUrl      String?
  scormManifestPath   String?
  scormPackageVersion Int      @default(1)
  isPublished         Boolean  @default(false)
  onChainSynced       Boolean  @default(false)
  onChainTxHash       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  lessons             Lesson[]
  enrollments         UserCourse[]
  scormRuns           ScormRun[]
  scoreActionNonces   ScoreActionNonce[]

  @@index([isIncentivized])
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ScormVersion {
  SCORM_12
  SCORM_2004
}

model Lesson {
  id              String   @id @default(cuid())
  courseId        Int
  title           String
  description     String?
  orderIndex      Int
  videoStorageKey String?
  videoDuration   Int
  watchPoints     Int      @default(10)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  course          Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)

  userProgress    UserLesson[]
  videos          LessonVideo[]
  notes           UserNote[]

  @@unique([courseId, orderIndex])
}

model LessonVideo {
  id           String   @id @default(cuid())
  lessonId     String
  language     String
  label        String
  storageKey   String
  duration     Int?
  orderIndex   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, language])
}

model UserNote {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}



model UserCourse {
  id                      String   @id @default(cuid())
  userId                  String
  courseId                Int
  enrolledAt              DateTime @default(now())
  pointsSpent             Int      @default(0)
  progressPercent         Int      @default(0)
  isCompleted             Boolean  @default(false)
  completedAt             DateTime?
  completionPointsAwarded Boolean  @default(false)
  onChainSynced           Boolean  @default(false)
  onChainCompletionSynced Boolean  @default(false)
  enrollTxHash            String?
  completionTxHash        String?

  engagementTimeScore     Int?
  baseScore               Int?
  actionBoostMultiplier   Float    @default(1)
  idMultiplier            Float    @default(1)
  finalScore              Int      @default(0)
  leaderboardEligible     Boolean  @default(false)
  completionFlags         Int      @default(0)
  proofSigned             Boolean  @default(false)
  proofSignedAt           DateTime?
  dappVisitTracked        Boolean  @default(false)
  dappVisitedAt           DateTime?

  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course                  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId, leaderboardEligible])
  @@index([courseId, finalScore])
}

model UserLesson {
  id                   String   @id @default(cuid())
  userId               String
  lessonId             String
  watchProgressPercent Int      @default(0)
  isWatched            Boolean  @default(false)
  watchPointsAwarded   Boolean  @default(false)

  watchedAt            DateTime?
  lastWatchedAt        DateTime?

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson               Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}



model ScormRun {
  id               String   @id @default(cuid())
  userId           String
  courseId         Int
  cmiState         Json
  completionStatus String?
  successStatus    String?
  rawScore         Float?
  scaledScore      Float?
  normalizedScore  Int?
  totalTimeSeconds Int      @default(0)
  initializedAt    DateTime @default(now())
  lastCommitAt     DateTime?
  terminatedAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course           Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId, normalizedScore])
}

model ScoreActionNonce {
  id         String   @id @default(cuid())
  userId     String
  courseId   Int
  nonce      String   @unique
  actionType String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId, courseId])
}

model BlockchainTx {
  id        String   @id @default(uuid())
  txHash    String   @unique
  type      TxType
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  Int
  status    TxStatus @default(PENDING)
  error     String?
  gasUsed   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([courseId])
  @@index([status])
}

enum TxStatus {
  PENDING
  SUCCESS
  FAILED
}

enum TxType {
  ENROLL
  COMPLETE
  PROGRESS_UPDATE
}

enum CampaignTier {
  LAUNCH_SPRINT
  DEEP_DIVE
  CUSTOM
}

enum CampaignStatus {
  DRAFT
  LIVE
  ENDED
  ARCHIVED
}

enum CampaignRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CampaignOwnerType {
  NEXID
  PARTNER
}

enum CampaignContractType {
  NEXID_CAMPAIGNS
  PARTNER_CAMPAIGNS
}

model Campaign {
  id                  Int            @id @default(autoincrement())
  slug                String         @unique
  title               String
  objective           String         @db.Text
  sponsorName         String
  sponsorNamespace    String?
  tier                CampaignTier   @default(LAUNCH_SPRINT)
  ownerType           CampaignOwnerType @default(PARTNER)
  contractType        CampaignContractType @default(PARTNER_CAMPAIGNS)
  prizePoolUsdc       Decimal        @db.Decimal(18, 6)
  keyTakeaways        String[]       @default([])
  coverImageUrl       String?
  modules             Json           @default("[]")
  status              CampaignStatus @default(DRAFT)
  isPublished         Boolean        @default(false)
  startAt             DateTime?
  endAt               DateTime?
  escrowAddress       String?
  escrowId            Int?
  onChainCampaignId   Int?
  /// Address of the PartnerCampaigns or NexIDCampaigns contract this campaign lives on
  partnerContractAddress String?
  claimMerkleRoot     String?
  claimTreeJson       Json?
  rewardSchedule      Json?
  requestId           String?        @unique

  /// Campaign difficulty enforcement (anti-dilution)
  minQuestions         Int            @default(5)
  passThreshold        Int            @default(80)
  difficultyWeight     Decimal        @default(1.0) @db.Decimal(3, 2)
  /// Whether escrow funds have been verified on-chain
  escrowVerified       Boolean        @default(false)
  escrowVerifiedAt     DateTime?

  /// Primary chain for on-chain verification: "base", "ethereum", "arbitrum", "hyperliquid", "megaeth", "other"
  primaryChain         String         @default("base")
  /// On-chain task config: { actionDescription, contractAddress, minAmountUsd, verificationMethod, rpcEndpoint?, chainId? }
  onchainConfig        Json?

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  request             CampaignRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  participants        CampaignParticipant[]
  domainClaims        DomainClaim[]
  distributions       CampaignRewardDistribution[]
  questions           Question[]
  quizAttempts        QuizAttempt[]
  onchainVerifications OnchainVerification[]

  @@index([status, isPublished])
  @@index([sponsorName])
  @@index([ownerType, contractType])
}

model CampaignRequest {
  id                 String                @id @default(cuid())
  submittedById      String?
  reviewedById       String?
  partnerName        String
  partnerNamespace   String?
  campaignTitle      String
  primaryObjective   String                @db.Text
  tier               CampaignTier
  prizePoolUsdc      Decimal               @db.Decimal(18, 6)
  briefFileName      String?
  callBookedFor      DateTime?
  callTimeSlot       String?
  callTimezone       String?
  callBookingNotes   String?               @db.Text
  status             CampaignRequestStatus @default(PENDING)
  reviewNotes        String?               @db.Text
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  submittedBy        User?                 @relation("SubmittedCampaignRequests", fields: [submittedById], references: [id], onDelete: SetNull)
  reviewedBy         User?                 @relation("ReviewedCampaignRequests", fields: [reviewedById], references: [id], onDelete: SetNull)
  campaign           Campaign?

  @@index([status, createdAt])
  @@index([partnerName])
}

model CampaignParticipant {
  id                String    @id @default(cuid())
  campaignId        Int
  userId            String
  score             Int       @default(0)
  onChainSyncedScore Int?
  completedUntil    Int       @default(-1)
  rank              Int?
  rewardAmountUsdc  Decimal?  @db.Decimal(18, 6)
  rewardTxHash      String?
  claimedAt         DateTime?
  claimSignature    String?
  enrolledAt        DateTime  @default(now())
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  flowStage         String?
  flowState         Json?
  flowStartedAt     DateTime?
  advocacyCompletedAt DateTime?
  advocacyPostUrl     String?
  advocacySubmittedAt DateTime?

  /// Server-authoritative per-item interaction receipts (e.g. "0-1" = group 0, item 1).
  /// /progress refuses to mark a group complete unless every non-locked item key in
  /// the group is present here, so the client can't loop /progress to skip gates.
  viewedItemKeys    String[]  @default([])

  /// Component scores (4-layer weighted scoring: Video 20%, Quiz 30%, Onchain 10%, Agent 40%)
  videoScore        Int?
  quizScore         Int?
  onchainScore      Int?
  agentScore        Int?
  compositeScore    Int?

  /// Graduated penalty multiplier applied (1.0 = no penalty, 0.5 = sybil cluster, etc.)
  penaltyMultiplier Float?

  /// Randomized quiz assignment: LIVE_AI (voice) or NORMAL_MCQ (text)
  quizAssignment    QuizAssignmentType?

  campaign              Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizAttempts          QuizAttempt[]
  onchainVerification   OnchainVerification?

  @@unique([campaignId, userId])
  @@index([campaignId, rank])
}

model DomainClaim {
  id            String   @id
  campaignId    Int
  userId        String
  walletAddress String
  domainName    String   @unique
  claimedAt     DateTime @default(now())

  campaign      Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([campaignId])
}

model CampaignRewardDistribution {
  id                  String    @id @default(cuid())
  campaignId          Int
  executedById        String?
  txHash              String?
  totalDistributedUsdc Decimal  @db.Decimal(18, 6)
  recipientCount      Int
  createdAt           DateTime  @default(now())

  campaign            Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  executedBy          User?     @relation("CampaignDistributionExecutor", fields: [executedById], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Living Passport — System 2 (Weekly On-Chain Scanner)
// ─────────────────────────────────────────────────────────────────────────────

/// Whitelisted smart contract addresses that the passport scanner watches.
/// Only interactions with these contracts count toward passport scores.
model PartnerContractWhitelist {
  id              String   @id @default(cuid())
  partnerId       String?
  campaignId      Int?
  chainId         Int
  contractAddress String
  /// LP, SWAP, GOVERNANCE, STAKE, MINT, BRIDGE, OTHER
  actionType      String
  label           String?
  isApproved      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([chainId, contractAddress])
  @@index([isApproved])
  @@index([chainId])
}

enum ScanCadence {
  WEEKLY
  MONTHLY
}

/// Composite passport score for each user, updated by the weekly scanner.
model PassportScore {
  id                     String      @id @default(cuid())
  userId                 String      @unique
  walletAddress          String

  /// Individual metric scores (0–100 each)
  frequencyScore         Int         @default(0)
  recencyScore           Int         @default(0)
  depthScore             Int         @default(0)
  varietyScore           Int         @default(0)
  volumeTier             Int         @default(0)

  /// Weighted composite (0–100)
  compositeScore         Int         @default(0)

  /// Rolling engagement tracking
  consecutiveActiveWeeks Int         @default(0)
  crossProtocolCount     Int         @default(0)

  scanCadence            ScanCadence @default(WEEKLY)
  lastScannedAt          DateTime?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  user                   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([compositeScore])
  @@index([scanCadence])
}

/// Immutable log of each wallet scan result for audit and trending.
model WalletScanLog {
  id                  String   @id @default(cuid())
  userId              String
  walletAddress       String
  scanDate            DateTime @default(now())
  chainId             Int
  /// JSON array of contract addresses interacted with
  contractsInteracted Json     @default("[]")
  /// JSON array of detected action types
  actionsDetected     Json     @default("[]")
  /// Number of distinct active days in the scanned window
  activeDays          Int      @default(0)
  /// Raw transaction count against whitelisted contracts
  txCount             Int      @default(0)

  @@index([userId, scanDate])
  @@index([walletAddress, chainId, scanDate])
}

// ─────────────────────────────────────────────────────────────────────────────
// Badge Identity Layer — System 3
// ─────────────────────────────────────────────────────────────────────────────

enum BadgeType {
  VERIFIED
  CONSISTENT
  RIGOROUS
  DEFI_ACTIVE
  DEFI_FLUENT
  DEFI_NATIVE
  PROTOCOL_SPECIALIST
  ZERO_FLAGS
  AGENT_CERTIFIED
  CROSS_CHAIN
  CHARTERED
  EARLY_ADOPTER
  PROTOCOL_ADVOCATE
}

/// A badge earned by a user. Once created, badges are permanent (never revoked).
model Badge {
  id          String    @id @default(cuid())
  userId      String
  type        BadgeType
  /// For PROTOCOL_SPECIALIST: the partner name/id
  partnerId   String?
  /// For campaign-triggered badges: which campaign
  campaignId  Int?
  earnedAt    DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// A user can only earn each badge type once (except PROTOCOL_SPECIALIST,
  /// which is unique per partner).
  @@unique([userId, type, partnerId])
  @@index([userId])
  @@index([type])
}

/// Tracks which 3 badges a user has selected to display publicly.
model UserBadgeDisplay {
  id       String @id @default(cuid())
  userId   String @unique
  /// Up to 3 badge IDs, stored as JSON array
  badgeIds Json   @default("[]")

  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 4: Anti-Sybil & Kill Switches
// ─────────────────────────────────────────────────────────────────────────────

enum SybilFlagReason {
  WALLET_AGE_BELOW_MINIMUM
  IP_CLUSTER
  DEVICE_FINGERPRINT_CLUSTER
  TX_TIMING_CLUSTER
  SHALLOW_ON_CHAIN_DEPTH
  AI_GENERATED_CONTENT
  MANUAL_REVIEW
}

model SybilFlag {
  id            String          @id @default(cuid())
  userId        String
  reason        SybilFlagReason
  severity      Int             @default(1)
  /// Machine-readable evidence payload (IP hash, fingerprint, wallet age, etc.)
  evidence      Json            @default("{}")
  /// Whether this flag has been reviewed by an admin
  reviewed      Boolean         @default(false)
  reviewedAt    DateTime?
  reviewedBy    String?
  /// Whether the flag was dismissed (false positive)
  dismissed     Boolean         @default(false)
  createdAt     DateTime        @default(now())

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([reason])
  @@index([reviewed])
}

model SessionFingerprint {
  id              String   @id @default(cuid())
  userId          String
  ipHash          String
  deviceHash      String?
  userAgentHash   String?
  sessionStart    DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([ipHash])
  @@index([deviceHash])
}

enum KillSwitchScope {
  GLOBAL
  CAMPAIGN
  USER
}

model KillSwitch {
  id          String          @id @default(cuid())
  scope       KillSwitchScope
  /// For CAMPAIGN scope: campaignId; for USER scope: userId; for GLOBAL: feature name
  targetId    String?
  feature     String
  enabled     Boolean         @default(true)
  reason      String?
  activatedBy String?
  activatedAt DateTime        @default(now())
  expiresAt   DateTime?

  @@unique([scope, targetId, feature])
  @@index([scope, enabled])
}

model EngagementFlag {
  id            String   @id @default(cuid())
  userId        String
  campaignId    Int?
  flagType      String
  /// Details: tab focus loss count, mouse entropy score, heartbeat anomaly, etc.
  details       Json     @default("{}")
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([campaignId])
  @@index([flagType])
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 6: ElevenLabs Agent Integration
// ─────────────────────────────────────────────────────────────────────────────

enum AgentSessionType {
  CAMPAIGN_ASSESSMENT
  CHARTERED_INTERVIEW
  PROTOCOL_ONBOARDING
  SCORE_DISPUTE
  SECURITY_SIMULATION
  PROOF_OF_OUTCOME_BRIEFING
  CAMPAIGN_DISCOVERY
  PRE_QUIZ_QA
}

enum AgentSessionStatus {
  QUEUED
  WALLET_CHALLENGE
  ACTIVE
  COMPLETED
  EXPIRED
  CANCELLED
}

model AgentSession {
  id                 String             @id @default(cuid())
  userId             String
  campaignId         Int?
  sessionType        AgentSessionType
  status             AgentSessionStatus @default(QUEUED)

  /// HMAC-signed session token (single-use, 90s expiry)
  sessionToken       String             @unique
  /// Single-use nonce for token replay prevention (nulled after verification)
  nonce              String?
  /// Token expiry timestamp (90-second window)
  tokenExpiresAt     DateTime?
  /// Wallet signature proving live ownership at session start
  walletSignature    String?
  /// Timestamp when wallet challenge was issued (30s expiry)
  challengeIssuedAt  DateTime?

  /// Gemini Live API conversation/session ID (was ElevenLabs)
  providerSessionId   String?

  /// Slot scheduling
  scheduledAt        DateTime?
  queuePosition      Int?

  /// Session timing
  startedAt          DateTime?
  completedAt        DateTime?
  durationSeconds    Int?
  maxDurationSeconds Int                @default(300)

  /// Scoring (for assessment/interview sessions)
  depthScore         Int?
  accuracyScore      Int?
  originalityScore   Int?
  overallScore       Int?
  /// Detailed scoring notes from agent
  scoringNotes       Json?

  /// Questions asked and responses (for audit/anti-outsourcing)
  transcript         Json?

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId, sessionType])
  @@index([userId])
  @@index([status])
  @@index([sessionType])
  @@index([scheduledAt])
}

model AgentSlotConfig {
  id                   String           @id @default(cuid())
  sessionType          AgentSessionType @unique
  /// Maximum concurrent sessions of this type
  maxConcurrent        Int              @default(25)
  /// Maximum session duration in seconds
  maxDurationSeconds   Int              @default(300)
  /// Whether this session type is currently enabled
  enabled              Boolean          @default(true)
  /// Top-N leaderboard cutoff for eligibility (0 = no limit)
  topNEligible         Int              @default(0)
  updatedAt            DateTime         @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Verification Tiers (.id Identity Layer)
// ─────────────────────────────────────────────────────────────────────────────

enum VerificationTier {
  NONE           // No campaigns completed
  BASIC          // Video + Quiz completed
  VERIFIED       // + Onchain action confirmed
  EXPERT         // + Agent session passed
}

// ─────────────────────────────────────────────────────────────────────────────
// Quiz Question Pool & Attempt System
// ─────────────────────────────────────────────────────────────────────────────

enum QuestionType {
  MCQ
  FREE_TEXT
}

enum QuizAssignmentType {
  LIVE_AI
  NORMAL_MCQ
}

model Question {
  id               String       @id @default(cuid())
  campaignId       Int
  type             QuestionType
  /// Primary question text
  questionText     String       @db.Text
  /// Alternative phrasings of the same question (anti-sharing defense)
  variants         Json         @default("[]")
  /// MCQ options (array of strings); null for FREE_TEXT
  options          Json?
  /// Index of the correct option (0-based); null for FREE_TEXT
  correctIndex     Int?
  /// Grading rubric/criteria for FREE_TEXT questions (sent to AI grader)
  gradingRubric    String?      @db.Text
  /// Points awarded for this question
  points           Int          @default(10)
  /// Difficulty tier: 1 (easy) to 3 (hard)
  difficulty       Int          @default(2)
  /// Tags for categorization (e.g., "tokenomics", "governance")
  tags             String[]     @default([])
  /// Whether this question can be used as a speed trap during video
  isSpeedTrap      Boolean      @default(false)
  /// Speed trap: time window in seconds to answer (null = no limit for pool questions)
  speedTrapWindow  Int?
  /// Whether this question is active in the pool
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  campaign         Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  answers          QuizAttemptAnswer[]

  @@index([campaignId, isActive])
  @@index([campaignId, type])
  @@index([campaignId, isSpeedTrap])
}

model QuizAttempt {
  id               String    @id @default(cuid())
  userId           String
  campaignId       Int
  participantId    String

  /// Which question IDs were drawn for this attempt (ordered)
  questionIds      Json
  /// Total score achieved (0-100 normalized)
  totalScore       Int?
  /// Number of questions answered correctly (MCQ) or passing (FREE_TEXT)
  correctCount     Int       @default(0)
  /// Whether the user exceeded the time limit on any question
  timeLimitExceeded Boolean  @default(false)
  /// Whether AI-generated content was detected in any answer
  aiContentDetected Boolean  @default(false)

  startedAt        DateTime  @default(now())
  completedAt      DateTime?

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign         Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  participant      CampaignParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  answers          QuizAttemptAnswer[]

  @@unique([userId, campaignId])
  @@index([campaignId])
  @@index([userId])
}

model QuizAttemptAnswer {
  id               String    @id @default(cuid())
  attemptId        String
  questionId       String
  /// Order in which this question was presented (0-based)
  questionOrder    Int

  /// For MCQ: the selected option index; for FREE_TEXT: null
  selectedIndex    Int?
  /// For FREE_TEXT: the user's written answer
  freeTextAnswer   String?   @db.Text
  /// Shuffled option order shown to user (array of original indices)
  shuffledOrder    Json?
  /// Whether the answer is correct (MCQ) or passed grading (FREE_TEXT)
  isCorrect        Boolean   @default(false)
  /// AI grading score for FREE_TEXT (0-100); null for MCQ
  aiGradingScore   Int?
  /// AI grading explanation/feedback
  aiGradingNotes   String?   @db.Text
  /// Whether AI-generated content was detected in this answer
  aiContentFlag    Boolean   @default(false)
  /// AI detection confidence (0.0-1.0)
  aiDetectionConfidence Float?
  /// Whether this is a follow-up question (chained from previous answer)
  isFollowUp       Boolean   @default(false)
  /// ID of the answer this follows up on (for chaining)
  followUpFromId   String?

  /// Timestamp when the question was shown to the user
  shownAt          DateTime?
  /// Timestamp when the answer was submitted
  answeredAt       DateTime?
  /// Time taken in seconds
  timeTakenSeconds Int?

  attempt          QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question         Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Speed Trap Configuration
// ─────────────────────────────────────────────────────────────────────────────

model SpeedTrapInstance {
  id               String   @id @default(cuid())
  campaignId       Int
  userId           String
  questionId       String
  /// Timestamp in the video (seconds) where the trap fires
  triggerTimestamp  Float
  /// Whether the user answered correctly
  answeredCorrectly Boolean?
  /// Whether the user timed out
  timedOut          Boolean  @default(false)
  /// Time taken to answer (seconds)
  responseTime      Float?
  createdAt         DateTime @default(now())

  @@unique([campaignId, userId, questionId])
  @@index([campaignId, userId])
}

/// User-submitted on-chain action verification for a campaign
model OnchainVerification {
  id               String    @id @default(cuid())
  campaignId       Int
  userId           String
  participantId    String    @unique
  /// "transaction" (submit tx hash) or "signature" (sign a message)
  verificationMode String    @default("transaction")
  txHash           String?
  /// Signed message content (for signature mode)
  signedMessage    String?
  /// Wallet signature hex (for signature mode)
  signature        String?
  /// Chain identifier: "base", "ethereum", "arbitrum", "hyperliquid", "megaeth", "other"
  chain            String
  verified         Boolean   @default(false)
  verifiedAt       DateTime?
  /// USD value of the verified transaction (if applicable)
  amountUsd        Decimal?  @db.Decimal(18, 6)
  /// Raw parsed transaction data for audit trail
  rawData          Json?
  createdAt        DateTime  @default(now())

  campaign         Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  participant      CampaignParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([txHash])
}
