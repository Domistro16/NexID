# NexAcademy Webapp environment variables
# Copy to `.env` or `.env.local` and fill in the values for your deployment.

# ------------------------------------------------------------------------------
# Core app
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/nexacademy

# Public app URL used in OAuth redirects and browser-side links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Auth and session secrets
# ------------------------------------------------------------------------------
# Required for JWT auth tokens.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Optional. If empty, agent session tokens fall back to JWT_SECRET.
SESSION_TOKEN_SECRET=

# ------------------------------------------------------------------------------
# Base chain and RPC
# ------------------------------------------------------------------------------
CHAIN_ID=8453
RPC_URL=https://mainnet.base.org

# Used by passport scans, sybil checks, and some on-chain verification flows.
ALCHEMY_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Browser-side RPC config.
NEXT_PUBLIC_CHAIN_ID=8453
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_RPC_URL=https://mainnet.base.org

# ------------------------------------------------------------------------------
# On-chain contracts: server-side
# ------------------------------------------------------------------------------
# Current campaign contracts
NEXID_CAMPAIGNS_ADDRESS=0x
PARTNER_CAMPAIGNS_ADDRESS=0x
CAMPAIGN_ESCROW_ADDRESS=0x
LEVEL3_COURSE_ADDRESS=0x

# Legacy contracts still referenced for older campaigns
PARTNER_CAMPAIGNS_V1_ADDRESS=
CAMPAIGN_ESCROW_V1_ADDRESS=

# Base USDC used in escrow/intake checks
BASE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# ------------------------------------------------------------------------------
# On-chain contracts: public/browser
# ------------------------------------------------------------------------------
NEXT_PUBLIC_NEXID_CAMPAIGNS_ADDRESS=0x
NEXT_PUBLIC_PARTNER_CAMPAIGNS_ADDRESS=0x
NEXT_PUBLIC_CAMPAIGN_ESCROW_ADDRESS=0x
NEXT_PUBLIC_LEVEL3_COURSE_ADDRESS=0x
NEXT_PUBLIC_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Domain admin controller addresses
NEXT_PUBLIC_CONTROLLER_ADDRESS=0xB5f3F983368e993b5f42D1dd659e4dC36fa5C494
NEXT_PUBLIC_AGENT_REGISTRAR_CONTROLLER_ADDRESS=0xB5f3F983368e993b5f42D1dd659e4dC36fa5C494

# ------------------------------------------------------------------------------
# Relayer and owner wallets
# ------------------------------------------------------------------------------
# Required for relayed enroll / complete / points updates.
RELAYER_PRIVATE_KEY=0x

# Required for owner-only campaign / escrow operations.
OWNER_PRIVATE_KEY=0x

# ------------------------------------------------------------------------------
# Admin access
# ------------------------------------------------------------------------------
# Comma-separated admin wallet addresses.
ADMIN_ADDRESSES=0xadmin1,0xadmin2

# ------------------------------------------------------------------------------
# Cron and background jobs
# ------------------------------------------------------------------------------
CRON_SECRET=replace-with-a-long-random-cron-secret

# ------------------------------------------------------------------------------
# Discord verification
# ------------------------------------------------------------------------------
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

# ------------------------------------------------------------------------------
# Privy / wallet auth
# ------------------------------------------------------------------------------
NEXT_PUBLIC_PRIVY_APP_ID=

# ------------------------------------------------------------------------------
# Gemini Live assessment
# ------------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_VOICE_NAME=Kore
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# ------------------------------------------------------------------------------
# AI grading and detection
# ------------------------------------------------------------------------------
# Set one or both. Anthropic is preferred where available, OpenAI is used as fallback.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ------------------------------------------------------------------------------
# Storage: S3 / Cloudflare R2
# ------------------------------------------------------------------------------
# Needed for video upload / storage features.
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=safuacademy-videos

# ------------------------------------------------------------------------------
# Security and anti-sybil
# ------------------------------------------------------------------------------
# 32-byte hex key used to encrypt notes at rest.
NOTES_ENCRYPTION_KEY=

# Salt used when hashing sybil / device fingerprints.
SYBIL_HASH_SALT=

# ------------------------------------------------------------------------------
# Platform and scoring
# ------------------------------------------------------------------------------
# ISO date string used by the badge engine for early-adopter logic.
NEXID_LAUNCH_DATE=
