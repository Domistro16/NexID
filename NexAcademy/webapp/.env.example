# ─────────────────────────────────────────────────────────────────────────────
# NexAcademy Webapp — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/nexacademy

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── Blockchain (Base) ────────────────────────────────────────────────────────
CHAIN_ID=8453
RPC_URL=https://mainnet.base.org
ALCHEMY_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Contract Addresses (v2 — current deployment) ────────────────────────────
NEXID_CAMPAIGNS_ADDRESS=0x
PARTNER_CAMPAIGNS_ADDRESS=0x
CAMPAIGN_ESCROW_ADDRESS=0x
LEVEL3_COURSE_ADDRESS=0x
BASE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# ── Legacy v1 Contract Addresses (for campaigns deployed before v2) ──────────
PARTNER_CAMPAIGNS_V1_ADDRESS=
CAMPAIGN_ESCROW_V1_ADDRESS=

# ── Relayer & Owner Wallets ──────────────────────────────────────────────────
# Relayer: sends enroll/complete/addPoints txs (gas payer)
RELAYER_PRIVATE_KEY=
# Owner: sends createCampaign/setClaimRoot/escrow txs (contract owner)
OWNER_PRIVATE_KEY=

# ── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated wallet addresses with admin access
ADMIN_ADDRESSES=0xadmin1,0xadmin2

# ── Cron Jobs ────────────────────────────────────────────────────────────────
# Bearer token for authenticating cron endpoints
CRON_SECRET=

# ── Discord OAuth ────────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

# ── Privy (Wallet Connect) ──────────────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Public (exposed to browser) ─────────────────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=8453
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_NEXID_CAMPAIGNS_ADDRESS=0x
NEXT_PUBLIC_PARTNER_CAMPAIGNS_ADDRESS=0x
NEXT_PUBLIC_LEVEL3_COURSE_ADDRESS=0x
NEXT_PUBLIC_CONTROLLER_ADDRESS=0x
NEXT_PUBLIC_AGENT_REGISTRAR_CONTROLLER_ADDRESS=0x

# ── Google Gemini (Voice Agent Sessions via Gemini Live API) ─────────────────
GEMINI_API_KEY=
# Voice preset for Gemini Live (e.g. Kore, Puck, Charon, Fenrir, Aoede)
GEMINI_VOICE_NAME=Kore
# Model for live sessions (default: gemini-2.5-flash-native-audio-preview)
GEMINI_LIVE_MODEL=gemini-2.5-flash-audio-preview

# ── S3 / Cloudflare R2 (video storage) ──────────────────────────────────────
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=safuacademy-videos

# ── Security ─────────────────────────────────────────────────────────────────
# 32-byte hex key for encrypting user notes at rest
NOTES_ENCRYPTION_KEY=
# Salt for hashing device/IP fingerprints in sybil detection
SYBIL_HASH_SALT=

# ── AI Grading & Detection ──────────────────────────────────────────────────
# Used for quiz free-text grading + AI-generated content detection
# Set one (or both). Anthropic preferred, OpenAI as fallback.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Platform ─────────────────────────────────────────────────────────────────
# ISO date string — used for Early Adopter badge cutoff (e.g. 2026-04-01)
NEXID_LAUNCH_DATE=
