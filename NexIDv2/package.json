{
  "name": "nexid-edgeboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "polymarket:derive-creds": "node scripts/derive-polymarket-creds.mjs",
    "positions:sync-open": "node scripts/sync-open-positions.mjs",
    "native-events:sync": "node scripts/sync-native-events.mjs",
    "native-resolution:run": "node scripts/run-native-resolution-bot.mjs",
    "test:proofflow": "node --test test/proofflow/*.test.mjs",
    "qa:smoke": "node scripts/production-smoke.mjs",
    "contracts:compile": "hardhat compile",
    "contracts:test": "hardhat test",
    "contracts:invariants": "hardhat test test/contracts/native-market-invariants.ts",
    "contracts:slither": "python -m slither . --config-file slither.config.json --exclude timestamp",
    "contracts:slither:full": "python -m slither . --config-file slither.config.json",
    "contracts:deploy:base-sepolia": "hardhat run scripts/contracts/deploy-base-sepolia.ts --network baseSepolia",
    "contracts:templates:base-sepolia": "hardhat run scripts/contracts/set-native-market-templates.ts --network baseSepolia",
    "contracts:deploy:edge-rewards:base-sepolia": "hardhat run scripts/contracts/deploy-edge-reward-distributor.ts --network baseSepolia",
    "contracts:fund:edge-rewards:base-sepolia": "hardhat run scripts/contracts/fund-edge-reward-distributor.ts --network baseSepolia",
    "contracts:verify:edge-rewards:base-sepolia": "hardhat run scripts/contracts/verify-edge-reward-distributor-flow.ts --network baseSepolia",
    "contracts:prepare:base-sepolia": "hardhat run scripts/contracts/prepare-base-sepolia-test-creator.ts --network baseSepolia",
    "contracts:deploy:base-mainnet": "hardhat run scripts/contracts/deploy-base-mainnet.ts --network base",
    "contracts:templates:base-mainnet": "hardhat run scripts/contracts/set-native-market-templates.ts --network base",
    "contracts:deploy:edge-rewards:base-mainnet": "hardhat run scripts/contracts/deploy-edge-reward-distributor.ts --network base",
    "contracts:fund:edge-rewards:base-mainnet": "hardhat run scripts/contracts/fund-edge-reward-distributor.ts --network base",
    "contracts:verify:edge-rewards:base-mainnet": "hardhat run scripts/contracts/verify-edge-reward-distributor-flow.ts --network base",
    "safe:predict:pools:base-sepolia": "node scripts/deploy-safe-pool-wallets.mjs baseSepolia --dry-run",
    "safe:predict:pools:base-mainnet": "node scripts/deploy-safe-pool-wallets.mjs base --dry-run",
    "safe:deploy:pools:base-sepolia": "node scripts/deploy-safe-pool-wallets.mjs baseSepolia",
    "safe:deploy:pools:base-mainnet": "node scripts/deploy-safe-pool-wallets.mjs base",
    "safe:set-recipients:base-sepolia": "node scripts/set-safe-pool-recipients.mjs baseSepolia",
    "safe:set-recipients:base-mainnet": "node scripts/set-safe-pool-recipients.mjs base",
    "contracts:proofflow:propose": "hardhat run scripts/contracts/propose-native-market-result.ts",
    "contracts:proofflow:finalize": "hardhat run scripts/contracts/finalize-native-market-result.ts",
    "contracts:grant-resolution-bot": "hardhat run scripts/contracts/grant-resolution-bot-roles.ts",
    "contracts:verify": "hardhat verify --network base"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1052.0",
    "@polymarket/clob-client-v2": "^1.0.6",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@safe-global/protocol-kit": "^7.2.0",
    "@tanstack/react-query": "^5.100.11",
    "next": "^16.2.6",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "viem": "^2.50.4",
    "wagmi": "^2.19.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@openzeppelin/contracts": "^5.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.5.0",
    "hardhat": "^2.28.0",
    "postcss": "^8.4.49",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
