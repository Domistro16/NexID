generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PositionSide {
  ride
  fade
}

enum OrderType {
  market
  limit
}

enum PositionStatus {
  pending
  live
  partial_fill
  filled
  closed
  resolved
  failed
}

enum IdStatus {
  reserved
  payment_pending
  active
  released
  failed
}

enum PaymentStatus {
  pending
  confirmed
  failed
}

enum ReceiptStatus {
  draft
  ready
  disputed
  archived
}

enum MarketOrigin {
  polymarket
  native
  draft
}

enum NexMarketStatus {
  draft
  route_check
  ready_to_launch
  live_pending_open
  trading_live
  closed
  result_proposed
  disputed
  settled
  invalid_refund
  cancelled_before_trading
}

enum MarketMatchType {
  exact
  related
  weak
  none
  blocked
  ambiguous
}

enum NativeOutcomeSide {
  ride
  fade
  invalid
}

model User {
  id                String                   @id @default(cuid())
  walletAddress     String                   @unique
  displayName       String?
  primaryIdName     String?
  pointsTotal       Int                      @default(0)
  edgeScoreTotal    Int                      @default(0)
  rewardLevel       String                   @default("Scout")
  rewardBadge       String                   @default("Signal Scout")
  rewardScoreTotal  Float                    @default(0)
  rewardEarnedUsd   Float                    @default(0)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  positions         Position[]
  receipts          Receipt[]
  ids               IdName[]
  referralsMade     Referral[]               @relation("ReferralReferrer")
  referralsGot      Referral[]               @relation("ReferralReferred")
  pointsEvents      PointsEvent[]
  feeLedgers        FeeLedger[]
  rewardAllocations RewardAllocation[]
  rewardPayouts     RewardPayout[]
  claimableLedgers  ClaimableBalanceLedger[]
  sessions          AuthSession[]
  polymarketAccount PolymarketAccount?
}

model PolymarketAccount {
  id                 String   @id @default(cuid())
  userId             String   @unique
  ownerWalletAddress String
  funderAddress      String
  signatureType      Int      @default(3)
  walletType         String   @default("deposit_wallet")
  source             String   @default("polymarket_profile")
  status             String   @default("ready")
  profileName        String?
  rawProfile         Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id])

  @@index([ownerWalletAddress])
  @@index([funderAddress])
}

model WalletNonce {
  id            String    @id @default(cuid())
  walletAddress String
  nonce         String    @unique
  message       String
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([walletAddress])
}

model AuthSession {
  id            String   @id @default(cuid())
  tokenHash     String   @unique
  userId        String
  walletAddress String
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([walletAddress])
}

model Narrative {
  id             String         @id
  name           String
  tag            String
  summary        String
  heat           Int
  move7d         Int
  quality        String
  liquidity      Float
  spread         Float
  volume         Float
  riders         Int
  faders         Int
  expiry         String
  top            String
  ridePrice      Float
  fadePrice      Float
  chart          Json
  comments       Json
  rules          Json
  bestMarketId   String?
  tradable       Boolean        @default(true)
  fallbackReason String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  markets        MappedMarket[]
  positions      Position[]
}

model MappedMarket {
  id              String     @id
  narrativeId     String
  question        String
  slug            String
  outcomes        Json
  outcomePrices   Json
  liquidity       Float
  volume24h       Float
  spread          Float
  expiry          DateTime?
  enableOrderBook Boolean    @default(false)
  qualityScore    Int
  sideMap         Json
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  narrative       Narrative  @relation(fields: [narrativeId], references: [id])
  positions       Position[]
}

model Position {
  id                     String         @id @default(cuid())
  userId                 String?
  narrativeId            String
  marketId               String?
  side                   PositionSide
  orderType              OrderType
  amount                 Float
  entryPrice             Float
  requestedWalletAddress String?
  executionMode          String         @default("disabled")
  orderIntent            Json?
  orderPreview           Json?
  marketQualityScore     Int?
  outcomeToken           String?
  executionId            String?
  builder                String?
  fillStatus             String?
  status                 PositionStatus @default(live)
  proof                  String?
  exitPrice              Float?
  settlementPrice        Float?
  exitValue              Float?
  settlementSource       String?
  settledAt              DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  user                   User?          @relation(fields: [userId], references: [id])
  narrative              Narrative      @relation(fields: [narrativeId], references: [id])
  market                 MappedMarket?  @relation(fields: [marketId], references: [id])
  receipt                Receipt?
}

model Receipt {
  id               String        @id @default(cuid())
  positionId       String        @unique
  userId           String?
  returnPct        Int
  proofLevel       String
  edgePoints       Int
  edgeScore        Int           @default(0)
  scoreBreakdown   Json?
  rank             String
  publicUrl        String
  cardAsset        String?
  status           ReceiptStatus @default(ready)
  resultSource     String?
  settlementSource String?
  settledAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  position         Position      @relation(fields: [positionId], references: [id])
  user             User?         @relation(fields: [userId], references: [id])
}

model PointsEvent {
  id        String   @id @default(cuid())
  userId    String?
  reason    String
  season    String   @default("Season 1")
  points    Int
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model RewardSeason {
  id                String             @id @default(cuid())
  code              String             @unique
  title             String
  status            String             @default("open")
  startsAt          DateTime
  endsAt            DateTime
  tradingRevenueUsd Float              @default(0)
  mintRevenueUsd    Float              @default(0)
  rewardPoolUsd     Float              @default(0)
  tradingPoolRate   Float              @default(0.9)
  mintPoolRate      Float              @default(0.25)
  levelWeights      Json
  finalizedAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  feeLedgers        FeeLedger[]
  allocations       RewardAllocation[]

  @@index([status, startsAt])
}

model FeeLedger {
  id                    String       @id @default(cuid())
  userId                String?
  seasonCode            String
  source                String
  sourceId              String?
  volumeUsd             Float        @default(0)
  grossRevenueUsd       Float        @default(0)
  nexidFeeUsd           Float        @default(0)
  rewardContributionUsd Float        @default(0)
  metadata              Json?
  createdAt             DateTime     @default(now())
  user                  User?        @relation(fields: [userId], references: [id])
  season                RewardSeason @relation(fields: [seasonCode], references: [code])

  @@unique([source, sourceId])
  @@index([userId, seasonCode])
  @@index([seasonCode, source])
}

model RewardAllocation {
  id                String        @id @default(cuid())
  seasonCode        String
  userId            String
  level             String
  badge             String
  lifetimePoints    Int           @default(0)
  weeklyScore       Float         @default(0)
  eligibleVolumeUsd Float         @default(0)
  feePaidUsd        Float         @default(0)
  realizedProfitUsd Float         @default(0)
  rewardShareUsd    Float         @default(0)
  status            String        @default("pending")
  riskFlag          String?
  breakdown         Json?
  reviewedAt        DateTime?
  paidAt            DateTime?
  txHash            String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  season            RewardSeason  @relation(fields: [seasonCode], references: [code])
  user              User          @relation(fields: [userId], references: [id])
  payout            RewardPayout?

  @@unique([seasonCode, userId])
  @@index([status, seasonCode])
  @@index([userId, seasonCode])
}

model RewardPayout {
  id           String           @id @default(cuid())
  allocationId String           @unique
  userId       String
  amountUsd    Float
  payoutMethod String           @default("manual")
  destination  String?
  status       String           @default("pending")
  txHash       String?
  note         String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  allocation   RewardAllocation @relation(fields: [allocationId], references: [id])
  user         User             @relation(fields: [userId], references: [id])

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model ClaimableBalanceLedger {
  id          String   @id @default(cuid())
  userId      String
  sourceType  String
  sourceId    String
  entryType   String
  status      String   @default("claimable")
  amountUsd   Float
  referenceId String?
  metadata    Json?
  txHash      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@unique([sourceType, sourceId, entryType])
  @@index([userId, status])
  @@index([userId, sourceType, status])
  @@index([referenceId])
}

model IdName {
  id            String        @id @default(cuid())
  name          String        @unique
  userId        String?
  status        IdStatus      @default(reserved)
  price         Float
  rarity        String
  reservedAt    DateTime      @default(now())
  expiresAt     DateTime?
  mintedAt      DateTime?
  paymentStatus PaymentStatus @default(pending)
  paymentRef    String?
  isPrimary     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User?         @relation(fields: [userId], references: [id])
}

model Referral {
  id             String   @id @default(cuid())
  referrerUserId String?
  referredUserId String?
  referrerIdName String
  mintName       String?
  mintPrice      Float
  rewardAmount   Float
  status         String   @default("pending")
  riskFlag       String?
  clicks         Int      @default(0)
  signups        Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  referrer       User?    @relation("ReferralReferrer", fields: [referrerUserId], references: [id])
  referred       User?    @relation("ReferralReferred", fields: [referredUserId], references: [id])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  name      String
  userId    String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model CardAsset {
  id        String   @id @default(cuid())
  type      String
  title     String
  format    String
  publicUrl String
  payload   Json?
  createdAt DateTime @default(now())
}

model BoardSnapshot {
  id        String   @id @default(cuid())
  boardKey  String
  title     String
  payload   Json
  createdAt DateTime @default(now())

  @@index([boardKey, createdAt])
}

model Market {
  id                       String          @id @default(cuid())
  origin                   MarketOrigin    @default(draft)
  status                   NexMarketStatus @default(draft)
  title                    String
  question                 String
  arena                    String
  template                 String?
  sourceUrl                String?
  closeTime                DateTime?
  polymarketMarketId       String?
  polymarketConditionId    String?
  polymarketClobTokenIds   Json?
  creatorUserId            String?
  creatorWallet            String?
  creatorIdentity          String?
  createdByType            String          @default("user")
  creatorAgentId           String?
  chainId                  Int?
  contractAddress          String?
  resolutionManagerAddress String?
  rulesHash                String?
  metadataHash             String?
  launchStakeStatus        String?
  resolutionState          String?
  sourceHealthStatus       String          @default("unknown")
  lastSourceCheckAt        DateTime?
  routeDecision            Json?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  @@index([origin, status])
  @@index([arena, status])
  @@index([polymarketMarketId])
  @@index([contractAddress])
  @@index([resolutionManagerAddress])
  @@index([rulesHash])
  @@index([createdByType, creatorAgentId])
  @@index([sourceHealthStatus, lastSourceCheckAt])
}

model MarketDraft {
  id            String   @id @default(cuid())
  userId        String?
  walletAddress String?
  rawThesis     String
  shaped        Json
  routeDecision Json?
  riskStatus    String
  marketId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([walletAddress, createdAt])
  @@index([riskStatus])
}

model MarketRouteMatch {
  id             String          @id @default(cuid())
  draftId        String?
  marketId       String?
  origin         MarketOrigin
  matchType      MarketMatchType
  candidateId    String?
  candidateTitle String?
  confidence     Float           @default(0)
  reason         String?
  raw            Json?
  createdAt      DateTime        @default(now())

  @@index([draftId])
  @@index([marketId])
  @@index([origin, matchType])
}

model NativeMarketRules {
  id                       String    @id @default(cuid())
  marketId                 String    @unique
  rulesHash                String    @unique
  metadataHash             String
  template                 String
  settlementSource         String
  closeTime                DateTime
  openTime                 DateTime?
  resolutionManagerAddress String?
  duplicateStatus          String    @default("none")
  riskStatus               String    @default("allowed")
  rawRules                 Json
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([template, riskStatus])
  @@index([resolutionManagerAddress])
}

model LaunchStake {
  id            String    @id @default(cuid())
  marketId      String    @unique
  stakeId       String?
  creatorWallet String
  totalUsdc     Float     @default(20)
  feeUsdc       Float     @default(10)
  bondUsdc      Float     @default(10)
  status        String    @default("pending")
  txHash        String?
  returnedAt    DateTime?
  slashedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([creatorWallet, status])
}

model NativePosition {
  id            String            @id @default(cuid())
  marketId      String
  userId        String?
  walletAddress String
  side          NativeOutcomeSide
  shares        Float             @default(0)
  notionalUsdc  Float             @default(0)
  status        String            @default("open")
  txHash        String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([marketId, walletAddress])
  @@index([userId, status])
}

model NativeTrade {
  id            String            @id @default(cuid())
  marketId      String
  positionId    String?
  walletAddress String
  side          NativeOutcomeSide
  notionalUsdc  Float
  feeUsdc       Float             @default(0)
  txHash        String
  eventLogIndex Int?
  createdAt     DateTime          @default(now())

  @@unique([txHash, eventLogIndex])
  @@index([marketId, createdAt])
  @@index([walletAddress, createdAt])
}

model MarketResolution {
  id                 String             @id @default(cuid())
  marketId           String
  proposedOutcome    NativeOutcomeSide?
  finalOutcome       NativeOutcomeSide?
  status             String             @default("pending")
  resolutionMode     String             @default("manual")
  proposerWallet     String?
  assertionId        String?            @unique
  assertionClaim     String?
  assertionTxHash    String?
  assertionDeadline  DateTime?
  settlementTxHash   String?
  evidence           Json?
  evidenceHash       String?
  verificationStatus String             @default("pending")
  confidence         Float?
  verifiedAt         DateTime?
  lastError          String?
  txHash             String?
  proposedAt         DateTime?
  finalizedAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([marketId, status])
  @@index([verificationStatus])
}

model MarketDispute {
  id             String   @id @default(cuid())
  marketId       String
  resolutionId   String?
  disputerWallet String?
  reason         String?
  status         String   @default("open")
  txHash         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([marketId, status])
}

model ContractDeployment {
  id           String   @id @default(cuid())
  chainId      Int
  network      String
  contractName String
  address      String
  version      String
  deployer     String?
  txHash       String?
  verifiedUrl  String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([chainId, contractName, version])
  @@index([chainId, address])
}

model OnchainEventCursor {
  id              String   @id @default(cuid())
  chainId         Int
  contractAddress String
  eventName       String
  lastBlock       Int      @default(0)
  lastLogIndex    Int      @default(0)
  updatedAt       DateTime @updatedAt

  @@unique([chainId, contractAddress, eventName])
}

model MarketReceipt {
  id            String             @id @default(cuid())
  marketId      String
  userId        String?
  walletAddress String?
  side          NativeOutcomeSide?
  title         String
  proof         String
  publicUrl     String?
  payload       Json?
  createdAt     DateTime           @default(now())

  @@index([marketId, createdAt])
  @@index([userId, createdAt])
}

model CreatorFeeLedger {
  id              String   @id @default(cuid())
  marketId        String
  creatorWallet   String
  sourceTxHash    String?
  volumeUsdc      Float    @default(0)
  creatorFeeUsdc  Float    @default(0)
  protocolFeeUsdc Float    @default(0)
  rewardsFeeUsdc  Float    @default(0)
  securityFeeUsdc Float    @default(0)
  createdAt       DateTime @default(now())

  @@index([marketId, createdAt])
  @@index([creatorWallet, createdAt])
}

model MarketTemplate {
  id            String   @id
  name          String
  arena         String
  status        String   @default("enabled")
  defaultSource String?
  riskPolicy    Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([arena, status])
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  action    String
  target    String
  metadata  Json?
  createdAt DateTime @default(now())
}

model BankrAiRequestLog {
  id               String   @id @default(cuid())
  requestId        String?
  feature          String
  userId           String?
  walletAddress    String?
  agentId          String?
  provider         String   @default("bankr")
  model            String
  fallbackModel    String?
  status           String
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  durationMs       Int?
  estimatedCostUsd Float?
  errorCode        String?
  errorMessage     String?
  metadata         Json?
  createdAt        DateTime @default(now())

  @@index([feature, status, createdAt])
  @@index([userId, createdAt])
  @@index([walletAddress, createdAt])
  @@index([agentId, createdAt])
}

model TrendingThesis {
  id                    String   @id @default(cuid())
  title                 String
  thesis                String
  arena                 String
  sourceUrl             String?
  fallbackSourceUrl     String?
  score                 Float    @default(0)
  measurabilityScore    Float    @default(0)
  sourceConfidenceScore Float    @default(0)
  status                String   @default("active")
  shaped                Json?
  routeDecision         Json?
  generatedBy           String   @default("bankr")
  metadata              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([status, score])
  @@index([arena, status])
  @@index([createdAt])
}

model SourceHealthCheck {
  id                String   @id @default(cuid())
  marketId          String
  sourceUrl         String?
  fallbackSourceUrl String?
  status            String
  httpStatus        Int?
  latencyMs         Int?
  staleReason       String?
  checkedBy         String   @default("bankr")
  detail            String?
  metadata          Json?
  createdAt         DateTime @default(now())

  @@index([marketId, createdAt])
  @@index([status, createdAt])
}

model CreatorNotificationPreference {
  id             String   @id @default(cuid())
  userId         String?
  walletAddress  String?
  email          String?
  telegramHandle String?
  telegramChatId String?
  channels       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([walletAddress])
}

model TelegramConnectToken {
  id            String    @id @default(cuid())
  token         String    @unique
  userId        String?
  walletAddress String?
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([walletAddress])
  @@index([expiresAt])
}

model CreatorNotification {
  id            String    @id @default(cuid())
  userId        String?
  walletAddress String?
  marketId      String?
  type          String
  channel       String    @default("dashboard")
  status        String    @default("unread")
  title         String
  body          String
  metadata      Json?
  sentAt        DateTime?
  readAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, status])
  @@index([walletAddress, status])
  @@index([marketId, type])
  @@index([createdAt])
}

model AgentApiKey {
  id              String    @id @default(cuid())
  name            String
  keyHash         String    @unique
  status          String    @default("active")
  walletAddress   String?
  identity        String?
  userId          String?
  scopes          Json?
  monthlyLimitUsd Float?
  requestsToday   Int       @default(0)
  lastUsedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([walletAddress, status])
  @@index([userId, status])
}

model AgentMarketAuditLog {
  id        String   @id @default(cuid())
  agentId   String?
  marketId  String?
  action    String
  status    String
  requestIp String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([agentId, action])
  @@index([marketId])
  @@index([createdAt])
}
