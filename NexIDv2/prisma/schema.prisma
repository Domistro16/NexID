generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PositionSide {
  ride
  fade
}

enum OrderType {
  market
  limit
}

enum PositionStatus {
  pending
  live
  partial_fill
  filled
  closed
  resolved
  failed
}

enum IdStatus {
  reserved
  payment_pending
  active
  released
  failed
}

enum PaymentStatus {
  pending
  confirmed
  failed
}

enum ReceiptStatus {
  draft
  ready
  disputed
  archived
}

enum MarketOrigin {
  polymarket
  native
  draft
}

enum NexMarketStatus {
  draft
  route_check
  ready_to_launch
  live_pending_open
  trading_live
  closed
  result_proposed
  disputed
  settled
  invalid_refund
  cancelled_before_trading
}

enum MarketMatchType {
  exact
  related
  weak
  none
  blocked
  ambiguous
}

enum NativeOutcomeSide {
  ride
  fade
  invalid
}

enum ProofFlowSettlementStatus {
  draft
  live
  closed
  provisional
  challenge_open
  evidence_review
  finalized_yes
  finalized_no
  finalized_invalid
  refunded
  additional_review
}

model User {
  id                        String                      @id @default(cuid())
  walletAddress             String                      @unique
  displayName               String?
  primaryIdName             String?
  pointsTotal               Int                         @default(0)
  edgeScoreTotal            Int                         @default(0)
  rewardLevel               String                      @default("Scout")
  rewardBadge               String                      @default("Signal Scout")
  rewardScoreTotal          Float                       @default(0)
  rewardEarnedUsd           Float                       @default(0)
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  positions                 Position[]
  receipts                  Receipt[]
  ids                       IdName[]
  referralsMade             Referral[]                  @relation("ReferralReferrer")
  referralsGot              Referral[]                  @relation("ReferralReferred")
  pointsEvents              PointsEvent[]
  feeLedgers                FeeLedger[]
  rewardAllocations         RewardAllocation[]
  rewardPayouts             RewardPayout[]
  claimableLedgers          ClaimableBalanceLedger[]
  sessions                  AuthSession[]
  polymarketAccount         PolymarketAccount?
  proofFlowReviews          ProofFlowReviewAssignment[]
  proofFlowReviewerAccesses ProofFlowReviewerAccess[]
  marketComments            MarketComment[]
  orderbookOrders           MarketOrderbookOrder[]
  nativeTargetOrders        NativeTargetOrder[]
  proofFlowProverProfile    ProofFlowProver?
}

model PolymarketAccount {
  id                 String   @id @default(cuid())
  userId             String   @unique
  ownerWalletAddress String
  funderAddress      String
  signatureType      Int      @default(3)
  walletType         String   @default("deposit_wallet")
  source             String   @default("polymarket_profile")
  status             String   @default("ready")
  profileName        String?
  rawProfile         Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id])

  @@index([ownerWalletAddress])
  @@index([funderAddress])
}

model WalletNonce {
  id            String    @id @default(cuid())
  walletAddress String
  nonce         String    @unique
  message       String
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([walletAddress])
}

model AuthSession {
  id            String   @id @default(cuid())
  tokenHash     String   @unique
  userId        String
  walletAddress String
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([walletAddress])
}

model Narrative {
  id             String         @id
  name           String
  tag            String
  summary        String
  heat           Int
  move7d         Int
  quality        String
  liquidity      Float
  spread         Float
  volume         Float
  riders         Int
  faders         Int
  expiry         String
  top            String
  ridePrice      Float
  fadePrice      Float
  chart          Json
  comments       Json
  rules          Json
  bestMarketId   String?
  tradable       Boolean        @default(true)
  fallbackReason String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  markets        MappedMarket[]
  positions      Position[]
}

model MappedMarket {
  id              String     @id
  narrativeId     String
  question        String
  slug            String
  outcomes        Json
  outcomePrices   Json
  liquidity       Float
  volume24h       Float
  spread          Float
  expiry          DateTime?
  enableOrderBook Boolean    @default(false)
  qualityScore    Int
  sideMap         Json
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  narrative       Narrative  @relation(fields: [narrativeId], references: [id])
  positions       Position[]

  @@index([narrativeId])
}

model Position {
  id                     String         @id @default(cuid())
  userId                 String?
  narrativeId            String
  marketId               String?
  side                   PositionSide
  orderType              OrderType
  amount                 Float
  entryPrice             Float
  requestedWalletAddress String?
  executionMode          String         @default("disabled")
  orderIntent            Json?
  orderPreview           Json?
  marketQualityScore     Int?
  outcomeToken           String?
  executionId            String?
  builder                String?
  fillStatus             String?
  status                 PositionStatus @default(live)
  proof                  String?
  exitPrice              Float?
  settlementPrice        Float?
  exitValue              Float?
  settlementSource       String?
  settledAt              DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  user                   User?          @relation(fields: [userId], references: [id])
  narrative              Narrative      @relation(fields: [narrativeId], references: [id])
  market                 MappedMarket?  @relation(fields: [marketId], references: [id])
  receipt                Receipt?
}

model Receipt {
  id               String        @id @default(cuid())
  positionId       String        @unique
  userId           String?
  returnPct        Int
  proofLevel       String
  edgePoints       Int
  edgeScore        Int           @default(0)
  scoreBreakdown   Json?
  rank             String
  publicUrl        String
  cardAsset        String?
  status           ReceiptStatus @default(ready)
  resultSource     String?
  settlementSource String?
  settledAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  position         Position      @relation(fields: [positionId], references: [id])
  user             User?         @relation(fields: [userId], references: [id])
}

model PointsEvent {
  id        String   @id @default(cuid())
  userId    String?
  reason    String
  season    String   @default("Season 1")
  points    Int
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model RewardSeason {
  id                String             @id @default(cuid())
  code              String             @unique
  title             String
  status            String             @default("open")
  startsAt          DateTime
  endsAt            DateTime
  tradingRevenueUsd Float              @default(0)
  mintRevenueUsd    Float              @default(0)
  rewardPoolUsd     Float              @default(0)
  tradingPoolRate   Float              @default(0.9)
  mintPoolRate      Float              @default(0.25)
  levelWeights      Json
  finalizedAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  feeLedgers        FeeLedger[]
  allocations       RewardAllocation[]

  @@index([status, startsAt])
}

model FeeLedger {
  id                    String       @id @default(cuid())
  userId                String?
  seasonCode            String
  source                String
  sourceId              String?
  volumeUsd             Float        @default(0)
  grossRevenueUsd       Float        @default(0)
  nexidFeeUsd           Float        @default(0)
  rewardContributionUsd Float        @default(0)
  metadata              Json?
  createdAt             DateTime     @default(now())
  user                  User?        @relation(fields: [userId], references: [id])
  season                RewardSeason @relation(fields: [seasonCode], references: [code])

  @@unique([source, sourceId])
  @@index([userId, seasonCode])
  @@index([seasonCode, source])
}

model RewardAllocation {
  id                String        @id @default(cuid())
  seasonCode        String
  userId            String
  level             String
  badge             String
  lifetimePoints    Int           @default(0)
  weeklyScore       Float         @default(0)
  eligibleVolumeUsd Float         @default(0)
  feePaidUsd        Float         @default(0)
  realizedProfitUsd Float         @default(0)
  rewardShareUsd    Float         @default(0)
  status            String        @default("pending")
  riskFlag          String?
  breakdown         Json?
  reviewedAt        DateTime?
  paidAt            DateTime?
  txHash            String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  season            RewardSeason  @relation(fields: [seasonCode], references: [code])
  user              User          @relation(fields: [userId], references: [id])
  payout            RewardPayout?

  @@unique([seasonCode, userId])
  @@index([status, seasonCode])
  @@index([userId, seasonCode])
}

model RewardPayout {
  id           String           @id @default(cuid())
  allocationId String           @unique
  userId       String
  amountUsd    Float
  payoutMethod String           @default("manual")
  destination  String?
  status       String           @default("pending")
  txHash       String?
  note         String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  allocation   RewardAllocation @relation(fields: [allocationId], references: [id])
  user         User             @relation(fields: [userId], references: [id])

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model ClaimableBalanceLedger {
  id          String   @id @default(cuid())
  userId      String
  sourceType  String
  sourceId    String
  entryType   String
  status      String   @default("claimable")
  amountUsd   Float
  referenceId String?
  metadata    Json?
  txHash      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@unique([sourceType, sourceId, entryType])
  @@index([userId, status])
  @@index([userId, sourceType, status])
  @@index([referenceId])
}

model IdName {
  id            String        @id @default(cuid())
  name          String        @unique
  userId        String?
  status        IdStatus      @default(reserved)
  price         Float
  rarity        String
  reservedAt    DateTime      @default(now())
  expiresAt     DateTime?
  mintedAt      DateTime?
  paymentStatus PaymentStatus @default(pending)
  paymentRef    String?
  isPrimary     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User?         @relation(fields: [userId], references: [id])
}

model Referral {
  id             String   @id @default(cuid())
  referrerUserId String?
  referredUserId String?
  referrerIdName String
  mintName       String?
  mintPrice      Float
  rewardAmount   Float
  status         String   @default("pending")
  riskFlag       String?
  clicks         Int      @default(0)
  signups        Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  referrer       User?    @relation("ReferralReferrer", fields: [referrerUserId], references: [id])
  referred       User?    @relation("ReferralReferred", fields: [referredUserId], references: [id])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  name      String
  userId    String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model CardAsset {
  id        String   @id @default(cuid())
  type      String
  title     String
  format    String
  publicUrl String
  payload   Json?
  createdAt DateTime @default(now())
}

model BoardSnapshot {
  id        String   @id @default(cuid())
  boardKey  String
  title     String
  payload   Json
  createdAt DateTime @default(now())

  @@index([boardKey, createdAt])
}

model Market {
  id                        String                 @id @default(cuid())
  origin                    MarketOrigin           @default(draft)
  status                    NexMarketStatus        @default(draft)
  title                     String
  question                  String
  arena                     String
  template                  String?
  sourceUrl                 String?
  closeTime                 DateTime?
  polymarketMarketId        String?
  polymarketConditionId     String?
  polymarketClobTokenIds    Json?
  creatorUserId             String?
  creatorWallet             String?
  creatorIdentity           String?
  createdByType             String                 @default("user")
  creatorAgentId            String?
  creatorAgentProfileId     String?
  creatorAgentPublicId      String?
  chainId                   Int?
  contractAddress           String?
  resolutionManagerAddress  String?
  rulesHash                 String?
  metadataHash              String?
  launchStakeStatus         String?
  resolutionState           String?
  resolutionCard            Json?
  settlementMode            String?
  backupSourceUrl           String?
  yesRule                   String?
  noRule                    String?
  invalidRule               String?
  challengeWindowSeconds    Int                    @default(86400)
  challengeWindowEndsAt     DateTime?
  settlementStatus          String                 @default("draft")
  provisionalOutcome        NativeOutcomeSide?
  finalOutcome              NativeOutcomeSide?
  auditSummary              String?
  finalResolutionNote       Json?
  bondAmount                Float?
  proposerBondStatus        String?
  challengerBondStatus      String?
  refundStatus              String?
  sourceHealthStatus        String                 @default("unknown")
  lastSourceCheckAt         DateTime?
  sourceQualificationStatus String?
  sourceQualificationScore  Int?
  sourceQualificationReason String?
  sourceValidationTimestamp DateTime?
  sourceRepairAttempts      Json?
  extractorValidationStatus String?
  extractorValidationReason String?
  dryRunStatus              String?
  dryRunResult              Json?
  routeDecision             Json?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  comments                  MarketComment[]
  orderbookOrders           MarketOrderbookOrder[]
  nativeTargetOrders        NativeTargetOrder[]

  @@index([origin, status])
  @@index([arena, status])
  @@index([polymarketMarketId])
  @@index([contractAddress])
  @@index([resolutionManagerAddress])
  @@index([rulesHash])
  @@index([createdByType, creatorAgentId])
  @@index([creatorAgentProfileId])
  @@index([creatorAgentPublicId])
  @@index([settlementStatus, challengeWindowEndsAt])
  @@index([sourceHealthStatus, lastSourceCheckAt])
  @@index([sourceQualificationStatus, sourceQualificationScore])
  @@index([updatedAt])
}

model MarketComment {
  id            String   @id @default(cuid())
  marketId      String
  userId        String?
  walletAddress String?
  authorLabel   String
  body          String   @db.VarChar(600)
  status        String   @default("visible")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  market        Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id])

  @@index([marketId, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([marketId, status, createdAt])
}

model MarketOrderbookOrder {
  id            String            @id @default(cuid())
  marketId      String
  userId        String?
  walletAddress String
  side          NativeOutcomeSide
  direction     String
  price         Float
  sizeUsdc      Float
  remainingUsdc Float
  filledUsdc    Float             @default(0)
  shareEstimate Float             @default(0)
  status        String            @default("open")
  source        String            @default("nexmarkets")
  executionId   String?
  expiresAt     DateTime?
  raw           Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  market        Market            @relation(fields: [marketId], references: [id], onDelete: Cascade)
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([marketId, status, side, direction, price])
  @@index([marketId, createdAt])
  @@index([walletAddress, status])
  @@index([userId, createdAt])
  @@index([marketId, status, remainingUsdc, createdAt])
}

model NativeTargetOrder {
  id              String            @id @default(cuid())
  marketId        String
  userId          String?
  walletAddress   String
  side            NativeOutcomeSide
  amountUsdc      Float
  targetPrice     Float
  maxPriceBps     Int
  depositUsdc     Float             @default(0)
  feeUsdc         Float             @default(0)
  status          String            @default("open")
  executorAddress String?
  executorOrderId String?
  createTxHash    String?
  executeTxHash   String?
  cancelTxHash    String?
  failureReason   String?
  expiresAt       DateTime?
  triggeredAt     DateTime?
  executedAt      DateTime?
  cancelledAt     DateTime?
  raw             Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  market          Market            @relation(fields: [marketId], references: [id], onDelete: Cascade)
  user            User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([executorAddress, executorOrderId])
  @@index([marketId, status, side, targetPrice])
  @@index([marketId, createdAt])
  @@index([walletAddress, status])
  @@index([userId, createdAt])
  @@index([status, expiresAt])
  @@index([status, executorAddress, createdAt])
  @@index([marketId, walletAddress, createdAt])
}

model MarketDraft {
  id                        String    @id @default(cuid())
  userId                    String?
  walletAddress             String?
  creatorAgentId            String?
  creatorAgentProfileId     String?
  rawThesis                 String
  shaped                    Json
  routeDecision             Json?
  riskStatus                String
  marketId                  String?
  sourceQualificationStatus String?
  sourceQualificationScore  Int?
  sourceQualificationReason String?
  sourceValidationTimestamp DateTime?
  sourceRepairAttempts      Json?
  extractorValidationStatus String?
  extractorValidationReason String?
  dryRunStatus              String?
  dryRunResult              Json?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([walletAddress, createdAt])
  @@index([creatorAgentId, createdAt])
  @@index([creatorAgentProfileId, createdAt])
  @@index([riskStatus])
  @@index([sourceQualificationStatus, sourceQualificationScore])
}

model MarketRouteMatch {
  id             String          @id @default(cuid())
  draftId        String?
  marketId       String?
  origin         MarketOrigin
  matchType      MarketMatchType
  candidateId    String?
  candidateTitle String?
  confidence     Float           @default(0)
  reason         String?
  raw            Json?
  createdAt      DateTime        @default(now())

  @@index([draftId])
  @@index([marketId])
  @@index([origin, matchType])
}

model NativeMarketRules {
  id                       String    @id @default(cuid())
  marketId                 String    @unique
  rulesHash                String    @unique
  metadataHash             String
  template                 String
  settlementSource         String
  closeTime                DateTime
  openTime                 DateTime?
  resolutionManagerAddress String?
  duplicateStatus          String    @default("none")
  riskStatus               String    @default("allowed")
  rawRules                 Json
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([template, riskStatus])
  @@index([resolutionManagerAddress])
}

model LaunchStake {
  id            String    @id @default(cuid())
  marketId      String    @unique
  stakeId       String?
  creatorWallet String
  totalUsdc     Float     @default(20)
  feeUsdc       Float     @default(10)
  bondUsdc      Float     @default(10)
  status        String    @default("pending")
  txHash        String?
  returnedAt    DateTime?
  slashedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([creatorWallet, status])
}

model NativePosition {
  id            String            @id @default(cuid())
  marketId      String
  userId        String?
  walletAddress String
  side          NativeOutcomeSide
  shares        Float             @default(0)
  notionalUsdc  Float             @default(0)
  status        String            @default("open")
  txHash        String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([marketId, walletAddress])
  @@index([userId, status])
  @@index([marketId, createdAt])
}

model NativeTrade {
  id            String            @id @default(cuid())
  marketId      String
  positionId    String?
  walletAddress String
  side          NativeOutcomeSide
  notionalUsdc  Float
  feeUsdc       Float             @default(0)
  txHash        String
  eventLogIndex Int?
  createdAt     DateTime          @default(now())

  @@unique([txHash, eventLogIndex])
  @@index([marketId, createdAt])
  @@index([walletAddress, createdAt])
}

model MarketResolution {
  id                    String                 @id @default(cuid())
  marketId              String
  proposedOutcome       NativeOutcomeSide?
  finalOutcome          NativeOutcomeSide?
  status                String                 @default("pending")
  resolutionMode        String                 @default("manual")
  proposerWallet        String?
  settlementMode        String?
  challengeWindowEndsAt DateTime?
  bondAmount            Float?
  proposerBondStatus    String?
  challengerBondStatus  String?
  refundStatus          String?
  auditSummary          String?
  finalResolutionNote   Json?
  assertionId           String?                @unique
  assertionClaim        String?
  assertionTxHash       String?
  assertionDeadline     DateTime?
  settlementTxHash      String?
  evidence              Json?
  evidenceHash          String?
  verificationStatus    String                 @default("pending")
  confidence            Float?
  verifiedAt            DateTime?
  lastError             String?
  txHash                String?
  proposedAt            DateTime?
  finalizedAt           DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  reviewPanels          ProofFlowReviewPanel[]

  @@index([marketId, status])
  @@index([verificationStatus])
  @@index([settlementMode, status])
  @@index([marketId, updatedAt])
}

model MarketDispute {
  id             String   @id @default(cuid())
  marketId       String
  resolutionId   String?
  disputerWallet String?
  reason         String?
  status         String   @default("open")
  txHash         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([marketId, status])
}

model ProofFlowEvidenceSubmission {
  id            String             @id @default(cuid())
  marketId      String
  resolutionId  String?
  kind          String
  outcome       NativeOutcomeSide?
  walletAddress String?
  evidenceUrl   String?
  evidenceText  String?
  sourceUrl     String?
  bondAmount    Float?
  bondStatus    String             @default("not_required")
  auditSummary  String?
  metadata      Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([marketId, kind, createdAt])
  @@index([resolutionId])
  @@index([walletAddress, createdAt])
}

model ProofFlowReviewerNote {
  id                 String             @id @default(cuid())
  marketId           String
  resolutionId       String?
  reviewerWallet     String?
  recommendedOutcome NativeOutcomeSide?
  note               String
  reputationDelta    Int                @default(0)
  rewardUsdc         Float              @default(0)
  metadata           Json?
  createdAt          DateTime           @default(now())

  @@index([marketId, createdAt])
  @@index([resolutionId])
  @@index([reviewerWallet, createdAt])
}

model ProofFlowReviewPanel {
  id                String                        @id @default(cuid())
  marketId          String
  resolutionId      String?
  round             Int
  status            String                        @default("open")
  reason            String?
  trigger           String?
  reviewDeadline    DateTime
  revealDeadline    DateTime
  selectedAt        DateTime                      @default(now())
  closedAt          DateTime?
  auditSummary      String?
  auditFlags        Json?
  auditClean        Boolean?
  consensusOutcome  NativeOutcomeSide?
  agreementCount    Int                           @default(0)
  notesSubmitted    Int                           @default(0)
  revealsCompleted  Int                           @default(0)
  missedRevealCount Int                           @default(0)
  coordinatedCount  Int                           @default(0)
  evidenceChangedAt DateTime?
  exposureUsdc      Float                         @default(0)
  rewardPoolUsdc    Float                         @default(50)
  monetaryEligible  Boolean                       @default(false)
  secondPanelForId  String?
  bestAssignmentId  String?
  metadata          Json?
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt
  resolution        MarketResolution?             @relation(fields: [resolutionId], references: [id])
  assignments       ProofFlowReviewAssignment[]
  triggers          ProofFlowSecondPanelTrigger[]
  rewards           ProofFlowReviewerReward[]

  @@unique([marketId, round])
  @@index([marketId, status])
  @@index([resolutionId])
  @@index([status, reviewDeadline])
}

model ProofFlowReviewAssignment {
  id                 String                    @id @default(cuid())
  panelId            String
  marketId           String
  resolutionId       String?
  reviewerUserId     String?
  reviewerWallet     String
  status             String                    @default("assigned")
  recommendedOutcome NativeOutcomeSide?
  noteHash           String?
  noteText           String?
  noteNonce          String?
  confidence         Float?
  commitTimestamp    DateTime?
  revealTimestamp    DateTime?
  evidenceUrl        String?
  sourceUrl          String?
  submittedAt        DateTime?
  revealedAt         DateTime?
  missedAt           DateTime?
  conflictDetectedAt DateTime?
